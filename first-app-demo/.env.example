# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored — your keys won't be committed.

# Gemini API key for LLM-based sound classification.
# Get one at: https://aistudio.google.com/apikey
# If left blank, the app falls back to the local heuristic classifier only.
VITE_GEMINI_API_KEY=
