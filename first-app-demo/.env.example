# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored — your keys won't be committed.

# OpenAI API key — primary LLM for audio classification + speech transcription.
# Get one at: https://platform.openai.com/api-keys
# If left blank, the app falls back to Gemini (if VITE_GEMINI_API_KEY set) or
# the local heuristic classifier.
VITE_OPENAI_API_KEY=

# Gemini API key — secondary fallback. Used only if OpenAI key is missing.
# Get one at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
